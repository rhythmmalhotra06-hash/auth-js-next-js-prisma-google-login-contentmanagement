DATABASE_URL=""

# Google OAuth (Auth.js provider)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Auth.js session secret (generate: openssl rand -base64 33)
AUTH_SECRET=""
# Required on non-Vercel hosts (local custom port, Cloud Run)
AUTH_TRUST_HOST="true"

# Airtable personal access token (scopes: schema.bases:read, data.records:read)
AIRTABLE_TOKEN=""

# Bearer secret for POST /api/sync/reference
SYNC_SECRET=""

# Anthropic API key for the Content Clipping Engine (E8).
# Deploy: set with `kessel env secret ANTHROPIC_API_KEY=...` before `kessel deploy`.
ANTHROPIC_API_KEY=""
