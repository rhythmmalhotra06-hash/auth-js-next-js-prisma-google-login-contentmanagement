DATABASE_URL=""

# Google OAuth (Auth.js provider)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Auth.js session secret (generate: openssl rand -base64 33)
AUTH_SECRET=""
# Required on non-Vercel hosts (local custom port, Cloud Run)
AUTH_TRUST_HOST="true"

# Airtable personal access token.
#   read-only (reference sync, live intake reads): schema.bases:read, data.records:read
#   two-way ticket push (Phase 2): ALSO needs data.records:write
AIRTABLE_TOKEN=""

# Bearer secret for the POST /api/sync/* routes (reference, push, …)
SYNC_SECRET=""

# Two-way ticket PUSH (portal → Airtable). Leave unset/false until the 0006 migration
# is applied AND AIRTABLE_TOKEN has data.records:write. When "true", ticket writes
# enqueue an outbox row and POST /api/sync/push drains it to Airtable.
AIRTABLE_PUSH_ENABLED="false"

# Anthropic API key for the Content Clipping Engine (E8).
# Deploy: set with `kessel env secret ANTHROPIC_API_KEY=...` before `kessel deploy`.
ANTHROPIC_API_KEY=""

# Vishen media → clip pipeline. Auto-detect (POST /api/media/discover) polls Vishen's
# YouTube channel uploads and adds New inbox rows (deduped on URL); clip generation
# stays button-triggered. Channel youtube.com/user/vishenlakhiani → UCgAvK6yXl3BtasS9mS0kefQ.
#   kessel env secret YOUTUBE_API_KEY=...         (YouTube Data API v3 key)
#   kessel env set    VISHEN_YT_CHANNEL_ID=UC...  (plain)
#   kessel env secret DISCOVER_SHARED_SECRET=...  (cron also sends it as the x-discover-secret header)
YOUTUBE_API_KEY=""
VISHEN_YT_CHANNEL_ID="UCgAvK6yXl3BtasS9mS0kefQ"
DISCOVER_SHARED_SECRET=""

# Supadata transcript API — primary auto-transcribe path. Runs its own residential
# proxies + AI fallback, so it works from the Cloud Run datacenter IP where YouTube
# blocks youtubei.js. When unset, transcript fetch falls back to best-effort
# youtubei.js (works locally; usually blocked when deployed) and to pasted transcripts.
#   kessel env secret SUPADATA_API_KEY=...  before `kessel deploy`
# Get a key at https://supadata.ai (free tier ~100 transcripts/mo).
SUPADATA_API_KEY=""

# Slack intake (Phase 2). POST /api/media/slack-scan reads a channel for shared
# YouTube links and adds them to the inbox (Submitted Via "Slack"). Outbound-only
# (the app is IAP-gated, so inbound Slack webhooks are blocked). Bot needs
# channels:history / groups:history and must be a member of the channel.
SLACK_BOT_TOKEN=""
SLACK_MEDIA_CHANNEL_ID=""

# BlinkLife push (portal → BlinkLife editor tasks / Vishen review / brief memories).
# Mirror of the Airtable outbox. Leave disabled until the 0007 migration is applied
# AND a token is set; when "true", ticket writes enqueue a row and
# POST /api/push/blinklife drains it via the BlinkLife MCP API.
BLINKLIFE_ENABLED="false"
BLINKLIFE_TOKEN=""                                    # personal MCP bearer token (single shared account for now)
BLINKLIFE_MCP_URL="https://api.blinklife.com/api/v1/mcp"
BLINKLIFE_PROJECT_NAME="Content Production"           # shared project tickets mirror into
BLINKLIFE_SYNC_SECRET=""                              # bearer for POST /api/push/blinklife (falls back to SYNC_SECRET)
# Absolute portal base URL, embedded as a deep link in each BlinkLife task.
APP_BASE_URL=""
