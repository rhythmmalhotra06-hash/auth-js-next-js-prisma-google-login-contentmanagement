generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

// ===========================================================================
// AUTH.JS  (identity/session only; domain attribution lives on Employee)
// ===========================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ===========================================================================
// REFERENCE DATA  (one-way: Airtable -> Postgres; read-only in the app)
// ===========================================================================

model Employee {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId     String?  @unique @map("airtable_id")
  name           String
  email          String?  @unique
  team           String? // ← Airtable "Creative Team (Editors)": Content Production Video | Marketing Video | Organic Social Video | Design
  division       String? // ← Airtable "MV Entity"
  isTeamLead     Boolean  @default(false) @map("is_team_lead")
  employmentType String   @default("employee") @map("employment_type") // ← Airtable "Employment Status"
  active         Boolean  @default(true) // ← Airtable "Active Status": Active | Not Active
  syncedAt       DateTime @default(now()) @map("synced_at") @db.Timestamptz

  assetTypeTeamLeads        AssetTypeTeamLead[]        @relation("AssetTypeTeamLead")
  assetTypePreferredEditors AssetTypePreferredEditor[] @relation("AssetTypePreferredEditor")
  assignedTickets           Ticket[]                   @relation("TicketAssignee")
  requestedTickets          Ticket[]                   @relation("TicketRequester")
  ticketEvents              TicketEvent[]
  approvals                 Approval[]
  contentSources            ContentSource[]            @relation("ContentSourceCreatedBy")

  @@map("employees")
}

model Dimension {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId String?  @unique @map("airtable_id")
  label      String // e.g. "9x16" — ← Airtable "Name" field
  syncedAt   DateTime @default(now()) @map("synced_at") @db.Timestamptz

  assetTypes AssetTypeDimension[]

  @@map("dimensions")
}

model EventType {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId     String?  @unique @map("airtable_id")
  name           String // e.g. Masterclass, Mastery, States, MBU, Social Media Promotion, Pathway
  brainProgramId String?  @map("brain_program_id") // [VERIFY] link to Mindvalley Brain
  active         Boolean  @default(true)
  syncedAt       DateTime @default(now()) @map("synced_at") @db.Timestamptz

  assetTypes AssetTypeEventType[]
  tickets    Ticket[]

  @@map("event_types")
}

model Dna {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId        String?  @unique @map("airtable_id")
  name              String
  requirements      String?
  feedbackStandards String?  @map("feedback_standards")
  syncedAt          DateTime @default(now()) @map("synced_at") @db.Timestamptz

  assetTypes AssetType[]

  @@map("dna")
}

model AssetType {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId        String?  @unique @map("airtable_id")
  name              String // e.g. "Masterclass Trailer"
  category          String? // ← Airtable "Type of Asset": Print | Digital
  dnaId             String?  @map("dna_id") @db.Uuid // DNA records live in the Ads Creative Library base
  active            Boolean  @default(true) // ← Airtable "Status": Active | Inactive
  syncedAt          DateTime @default(now()) @map("synced_at") @db.Timestamptz

  dna Dna? @relation(fields: [dnaId], references: [id])

  // Airtable models these as MULTIPLE record links → many-to-many (reconciliation 2026-06-25)
  eventTypes       AssetTypeEventType[]
  teamLeads        AssetTypeTeamLead[]
  preferredEditors AssetTypePreferredEditor[]

  dimensions AssetTypeDimension[]
  tickets    Ticket[]

  @@map("asset_types")
}

model AssetTypeDimension {
  assetTypeId String @map("asset_type_id") @db.Uuid
  dimensionId String @map("dimension_id") @db.Uuid

  assetType AssetType @relation(fields: [assetTypeId], references: [id], onDelete: Cascade)
  dimension Dimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  @@id([assetTypeId, dimensionId])
  @@map("asset_type_dimensions")
}

// Asset type ↔ event type (Airtable "Event Type" multi-link)
model AssetTypeEventType {
  assetTypeId String @map("asset_type_id") @db.Uuid
  eventTypeId String @map("event_type_id") @db.Uuid

  assetType AssetType @relation(fields: [assetTypeId], references: [id], onDelete: Cascade)
  eventType EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)

  @@id([assetTypeId, eventTypeId])
  @@map("asset_type_event_types")
}

// Asset type ↔ team lead employees (Airtable "Team Lead" multi-link)
model AssetTypeTeamLead {
  assetTypeId String @map("asset_type_id") @db.Uuid
  employeeId  String @map("employee_id") @db.Uuid

  assetType AssetType @relation(fields: [assetTypeId], references: [id], onDelete: Cascade)
  employee  Employee  @relation("AssetTypeTeamLead", fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([assetTypeId, employeeId])
  @@map("asset_type_team_leads")
}

// Asset type ↔ preferred editor employees (Airtable "Preferred Editors" multi-link)
model AssetTypePreferredEditor {
  assetTypeId String @map("asset_type_id") @db.Uuid
  employeeId  String @map("employee_id") @db.Uuid

  assetType AssetType @relation(fields: [assetTypeId], references: [id], onDelete: Cascade)
  employee  Employee  @relation("AssetTypePreferredEditor", fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([assetTypeId, employeeId])
  @@map("asset_type_preferred_editors")
}

// ===========================================================================
// TRANSACTIONAL DATA  (two-way: app is primary, pushed back to Airtable)
// ===========================================================================

model Ticket {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId    String?   @unique @map("airtable_id")
  title         String // renamed from "Summary" for Dropbox searchability
  creativeBrief String?   @map("creative_brief")
  cta           String? // ← Airtable "Call to action"
  positioning   String? // messaging angle
  audience      String? // 'cold' | 'warm'
  dueDate       DateTime? @map("due_date") @db.Date

  eventTypeId        String? @map("event_type_id") @db.Uuid
  assetTypeId        String? @map("asset_type_id") @db.Uuid
  assigneeId         String? @map("assignee_id") @db.Uuid // ← Airtable "Assigned Creative"
  requesterId        String? @map("requester_id") @db.Uuid // ← Airtable "Requested By" (drives downstream lookups)
  officialCalendarId String? @map("official_calendar_id") @db.Uuid // ← Airtable "Official Calendar"

  teamServiceLevel String? @map("team_service_level") // ← "Team/Service Level"
  typeOfRequest    String? @map("type_of_request") // ← "Type of Request": Video | Design
  sourceLinks      String? @map("source_links") // ← "Raw File/Source URL/Stage Talk Links"
  notes            String? // ← "V's Notes"

  // Two status axes (live values from reconciliation 2026-06-25):
  prioStatus   String? @map("prio_status") // New Request | To be reviewed by Vishen | In Queue | Pending Information/Brief Not Clear | Rejected - No need to work | Assigned
  ticketStatus String? @map("ticket_status") // Backlog | To Do | In Progress | Review | In Revision | Approved | Done | Won't Do | Shipping | Request on Hold

  urgency       Int?
  complexity    Int?
  priorityScore Decimal? @map("priority_score") @db.Decimal // derived; ranks the queue
  queueRank     Int?     @map("queue_rank") // ← Airtable "Priority ranking (Manual)"

  source    String    @default("app") // app | jira_migration | airtable
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  syncedAt  DateTime? @map("synced_at") @db.Timestamptz
  // Last time the app pushed this ticket to Airtable — echo-suppression window for
  // the (future) Phase 3 pull, so our own write doesn't ping-pong back.
  airtablePushedAt DateTime? @map("airtable_pushed_at") @db.Timestamptz
  // Last time the app mirrored this ticket into BlinkLife (editor task). Observability
  // + lets the reconcile pass skip tickets already current.
  blinklifePushedAt DateTime? @map("blinklife_pushed_at") @db.Timestamptz

  eventType        EventType?        @relation(fields: [eventTypeId], references: [id])
  assetType        AssetType?        @relation(fields: [assetTypeId], references: [id])
  assignee         Employee?         @relation("TicketAssignee", fields: [assigneeId], references: [id])
  requester        Employee?         @relation("TicketRequester", fields: [requesterId], references: [id])
  officialCalendar OfficialCalendar? @relation(fields: [officialCalendarId], references: [id])

  events    TicketEvent[]
  approvals Approval[]
  shoots    ShootTicket[]
  assets    Asset[]
  authors   TicketAuthor[]

  clipSuggestions ClipSuggestion[] @relation("TicketClipSuggestions")

  @@index([priorityScore(sort: Desc), queueRank], map: "idx_tickets_queue")
  @@index([assigneeId], map: "idx_tickets_assignee")
  @@index([ticketStatus], map: "idx_tickets_status")
  @@map("tickets")
}

// Phase 2 — outbox for two-way ticket PUSH (portal → Airtable). Ticket writes
// enqueue a row in the same transaction; a background drainer (drainOutbox) pushes
// current ticket state to the Prio Requests table, batched + rate-limited. We
// enqueue by ticketId (not a field snapshot) so the drainer always sends the
// latest state and collapses rapid successive edits.
model AirtableOutbox {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId    String    @map("ticket_id") @db.Uuid
  op          String    @default("upsert") // upsert (create-or-update)
  status      String    @default("pending") // pending | done | error
  attempts    Int       @default(0)
  lastError   String?   @map("last_error")
  enqueuedAt  DateTime  @default(now()) @map("enqueued_at") @db.Timestamptz
  processedAt DateTime? @map("processed_at") @db.Timestamptz

  @@index([status, enqueuedAt], map: "idx_outbox_pending")
  @@map("airtable_outbox")
}

// BlinkLife integration — mirror of the Airtable push outbox, for pushing editor
// tasks into BlinkLife (the team's personal-productivity OS). Ticket writes enqueue
// a row in the same transaction; drainBlinklifeOutbox sends current state via the
// BlinkLife MCP API. Separate from airtable_outbox so the two targets enable, fail,
// and schedule independently. Gated by BLINKLIFE_ENABLED.
model BlinkLifeOutbox {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId    String    @map("ticket_id") @db.Uuid
  op          String    @default("upsert") // upsert (create-or-update task)
  status      String    @default("pending") // pending | done | error
  attempts    Int       @default(0)
  lastError   String?   @map("last_error")
  enqueuedAt  DateTime  @default(now()) @map("enqueued_at") @db.Timestamptz
  processedAt DateTime? @map("processed_at") @db.Timestamptz

  @@index([status, enqueuedAt], map: "idx_blinklife_outbox_pending")
  @@map("blinklife_outbox")
}

// Provenance for entities the app creates inside BlinkLife (idempotency): the
// shared "Content Production" project, the per-ticket task, the Vishen review page,
// captured brief memories. Keyed by (kind, ticketId) so a re-push updates rather
// than duplicates. Singleton kinds (e.g. 'project') use a null ticketId.
model BlinkLifeRef {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kind       String // project | ticket_task | vishen_review_page | brief_memory
  ticketId   String?  @map("ticket_id") @db.Uuid
  externalId String   @map("external_id") // BlinkLife id (task/project/page/memory)
  syncedAt   DateTime @default(now()) @updatedAt @map("synced_at") @db.Timestamptz

  @@unique([kind, ticketId], map: "uniq_blinklife_ref")
  @@map("blinklife_refs")
}

model TicketEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId  String?  @map("ticket_id") @db.Uuid
  fromState String?  @map("from_state")
  toState   String   @map("to_state")
  actorId   String?  @map("actor_id") @db.Uuid
  note      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  ticket Ticket?   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor  Employee? @relation(fields: [actorId], references: [id])

  @@map("ticket_events")
}

model Approval {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId   String?   @map("ticket_id") @db.Uuid
  approverId String?   @map("approver_id") @db.Uuid
  state      String    @default("pending") // pending | approved | changes_requested
  feedback   String?
  decidedAt  DateTime? @map("decided_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  ticket   Ticket?   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  approver Employee? @relation(fields: [approverId], references: [id])

  @@map("approvals")
}

model Shoot {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId String?   @unique @map("airtable_id")
  title      String
  status     String? // New Requests - Approved by Vishen | New Requests - Needs Vishen's Review | To Film | Done - Filmed | Cancelled
  shootDate  DateTime? @map("shoot_date") @db.Date
  location   String?
  notes      String?
  syncedAt   DateTime  @default(now()) @map("synced_at") @db.Timestamptz

  tickets ShootTicket[]

  @@map("shoots")
}

model ShootTicket {
  shootId  String @map("shoot_id") @db.Uuid
  ticketId String @map("ticket_id") @db.Uuid

  shoot  Shoot  @relation(fields: [shootId], references: [id], onDelete: Cascade)
  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@id([shootId, ticketId])
  @@map("shoot_tickets")
}

model Asset {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId      String?   @unique @map("airtable_id")
  ticketId        String?   @map("ticket_id") @db.Uuid
  kind            String // 'raw' | 'final'
  name            String? // asset title (library imports have no ticket to name them)
  sourceTable     String?   @map("source_table") // provenance: which Airtable table/origin this asset came from
  fileUrl         String?   @map("file_url") // Dropbox / storage link
  distributionUrl String?   @map("distribution_url") // link to social media calendar entry
  publishedAt     DateTime? @map("published_at") @db.Timestamptz
  syncedAt        DateTime  @default(now()) @map("synced_at") @db.Timestamptz

  ticket      Ticket?       @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  performance Performance[]

  @@map("assets")
}

model Performance {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetId    String?  @map("asset_id") @db.Uuid
  metric     String // e.g. CTR, views, spend, ROAS
  value      Decimal? @db.Decimal
  capturedAt DateTime @default(now()) @map("captured_at") @db.Timestamptz
  source     String? // e.g. Clarisights, Amplitude, manual

  asset Asset? @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("performance")
}

// Official Calendar (reference, synced from Airtable) — campaign start/end dates.
model OfficialCalendar {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId  String?   @unique @map("airtable_id")
  name        String // ← "Name of project"
  status      String? // Proposal | Confirmed | Completed | …
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  syncedAt    DateTime  @default(now()) @map("synced_at") @db.Timestamptz

  tickets Ticket[]

  @@map("official_calendar")
}

// Authors / speakers (reference, synced from Airtable).
model Author {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId String?  @unique @map("airtable_id")
  name       String
  title      String? // ← "Author's Title"
  syncedAt   DateTime @default(now()) @map("synced_at") @db.Timestamptz

  tickets TicketAuthor[]

  @@map("authors")
}

// Ticket ↔ authors/speakers (Airtable "Speakers/Authors" multi-link).
model TicketAuthor {
  ticketId String @map("ticket_id") @db.Uuid
  authorId String @map("author_id") @db.Uuid

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@id([ticketId, authorId])
  @@map("ticket_authors")
}

// ===========================================================================
// AI CONTENT CLIPPING ENGINE (E8)
// Transcript → 10-section viral strategy → selectable clips → proposed tickets.
// ===========================================================================

// One long-form transcript + the context it was generated with.
model ContentSource {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String
  sourceType    String   @map("source_type") // paste | file | youtube
  sourceUrl     String?  @map("source_url")
  guestName     String?  @map("guest_name")
  guestAudience String?  @map("guest_audience")
  brandPillars  String?  @map("brand_pillars")
  transcript    String   @db.Text
  createdById   String?  @map("created_by_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  createdBy  Employee?      @relation("ContentSourceCreatedBy", fields: [createdById], references: [id])
  strategies ClipStrategy[]

  @@map("content_sources")
}

// One generation run: the full 10-section strategy lives in `output` (JSON).
model ClipStrategy {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contentSourceId String   @map("content_source_id") @db.Uuid
  model           String
  status          String   @default("generating") // generating | complete | error
  error           String?
  output          Json?
  usedWebSearch   Boolean  @default(false) @map("used_web_search")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  contentSource ContentSource    @relation(fields: [contentSourceId], references: [id], onDelete: Cascade)
  clips         ClipSuggestion[]

  @@index([contentSourceId], map: "idx_clip_strategies_source")
  @@map("clip_strategies")
}

// The Reels clips, broken out for propose → approve → ticket tracking.
model ClipSuggestion {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clipStrategyId String  @map("clip_strategy_id") @db.Uuid
  index          Int
  title          String
  timestampStart String? @map("timestamp_start")
  timestampEnd   String? @map("timestamp_end")
  rationale      String?
  caption        String?
  hookLine       String? @map("hook_line")
  format         String?
  platform       String?
  viralityScore  Int?    @map("virality_score")
  status         String  @default("proposed") // proposed | approved | dismissed
  ticketId       String? @map("ticket_id") @db.Uuid

  clipStrategy ClipStrategy @relation(fields: [clipStrategyId], references: [id], onDelete: Cascade)
  ticket       Ticket?      @relation("TicketClipSuggestions", fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([clipStrategyId], map: "idx_clip_suggestions_strategy")
  @@map("clip_suggestions")
}

// ===========================================================================
// METRIC SNAPSHOTS — precomputed aggregates
// ===========================================================================

// Precomputed aggregate snapshots so dashboards read one cheap row instead of
// scanning the ~10k-row Airtable ticket table on every page load. Refreshed by
// POST /api/metrics/refresh (nightly cron). `data` holds an arbitrary payload
// keyed by `key` (e.g. "ticket_status_counts" → { total, byStatus, shipped }).
model MetricSnapshot {
  key        String   @id
  data       Json
  computedAt DateTime @updatedAt @map("computed_at")

  @@map("metric_snapshots")
}
