generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
  runtime  = "edge-light"
}

datasource db {
  provider = "postgresql"
}

// ===========================================================================
// AUTH.JS  (identity/session only; domain attribution lives on Employee)
// ===========================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ===========================================================================
// REFERENCE DATA  (one-way: Airtable -> Postgres; read-only in the app)
// ===========================================================================

model Employee {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId     String?  @unique @map("airtable_id")
  name           String
  email          String?  @unique
  team           String? // ← Airtable "Creative Team (Editors)": Content Production Video | Marketing Video | Organic Social Video | Design
  division       String? // ← Airtable "MV Entity"
  isTeamLead     Boolean  @default(false) @map("is_team_lead")
  employmentType String   @default("employee") @map("employment_type") // ← Airtable "Employment Status"
  active         Boolean  @default(true) // ← Airtable "Active Status": Active | Not Active
  syncedAt       DateTime @default(now()) @map("synced_at") @db.Timestamptz

  assetTypeTeamLeads        AssetTypeTeamLead[]        @relation("AssetTypeTeamLead")
  assetTypePreferredEditors AssetTypePreferredEditor[] @relation("AssetTypePreferredEditor")
  assignedTickets           Ticket[]
  ticketEvents              TicketEvent[]
  approvals                 Approval[]

  @@map("employees")
}

model Dimension {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId String?  @unique @map("airtable_id")
  label      String // e.g. "9x16" — ← Airtable "Name" field
  syncedAt   DateTime @default(now()) @map("synced_at") @db.Timestamptz

  assetTypes AssetTypeDimension[]

  @@map("dimensions")
}

model EventType {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId     String?  @unique @map("airtable_id")
  name           String // e.g. Masterclass, Mastery, States, MBU, Social Media Promotion, Pathway
  brainProgramId String?  @map("brain_program_id") // [VERIFY] link to Mindvalley Brain
  active         Boolean  @default(true)
  syncedAt       DateTime @default(now()) @map("synced_at") @db.Timestamptz

  assetTypes AssetTypeEventType[]
  tickets    Ticket[]

  @@map("event_types")
}

model Dna {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId        String?  @unique @map("airtable_id")
  name              String
  requirements      String?
  feedbackStandards String?  @map("feedback_standards")
  syncedAt          DateTime @default(now()) @map("synced_at") @db.Timestamptz

  assetTypes AssetType[]

  @@map("dna")
}

model AssetType {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId        String?  @unique @map("airtable_id")
  name              String // e.g. "Masterclass Trailer"
  category          String? // ← Airtable "Type of Asset": Print | Digital
  dnaId             String?  @map("dna_id") @db.Uuid // DNA records live in the Ads Creative Library base
  active            Boolean  @default(true) // ← Airtable "Status": Active | Inactive
  syncedAt          DateTime @default(now()) @map("synced_at") @db.Timestamptz

  dna Dna? @relation(fields: [dnaId], references: [id])

  // Airtable models these as MULTIPLE record links → many-to-many (reconciliation 2026-06-25)
  eventTypes       AssetTypeEventType[]
  teamLeads        AssetTypeTeamLead[]
  preferredEditors AssetTypePreferredEditor[]

  dimensions AssetTypeDimension[]
  tickets    Ticket[]

  @@map("asset_types")
}

model AssetTypeDimension {
  assetTypeId String @map("asset_type_id") @db.Uuid
  dimensionId String @map("dimension_id") @db.Uuid

  assetType AssetType @relation(fields: [assetTypeId], references: [id], onDelete: Cascade)
  dimension Dimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  @@id([assetTypeId, dimensionId])
  @@map("asset_type_dimensions")
}

// Asset type ↔ event type (Airtable "Event Type" multi-link)
model AssetTypeEventType {
  assetTypeId String @map("asset_type_id") @db.Uuid
  eventTypeId String @map("event_type_id") @db.Uuid

  assetType AssetType @relation(fields: [assetTypeId], references: [id], onDelete: Cascade)
  eventType EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)

  @@id([assetTypeId, eventTypeId])
  @@map("asset_type_event_types")
}

// Asset type ↔ team lead employees (Airtable "Team Lead" multi-link)
model AssetTypeTeamLead {
  assetTypeId String @map("asset_type_id") @db.Uuid
  employeeId  String @map("employee_id") @db.Uuid

  assetType AssetType @relation(fields: [assetTypeId], references: [id], onDelete: Cascade)
  employee  Employee  @relation("AssetTypeTeamLead", fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([assetTypeId, employeeId])
  @@map("asset_type_team_leads")
}

// Asset type ↔ preferred editor employees (Airtable "Preferred Editors" multi-link)
model AssetTypePreferredEditor {
  assetTypeId String @map("asset_type_id") @db.Uuid
  employeeId  String @map("employee_id") @db.Uuid

  assetType AssetType @relation(fields: [assetTypeId], references: [id], onDelete: Cascade)
  employee  Employee  @relation("AssetTypePreferredEditor", fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([assetTypeId, employeeId])
  @@map("asset_type_preferred_editors")
}

// ===========================================================================
// TRANSACTIONAL DATA  (two-way: app is primary, pushed back to Airtable)
// ===========================================================================

model Ticket {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId    String?   @unique @map("airtable_id")
  title         String // renamed from "Summary" for Dropbox searchability
  creativeBrief String?   @map("creative_brief")
  cta           String? // ← Airtable "Call to action"
  positioning   String? // messaging angle
  audience      String? // 'cold' | 'warm'
  dueDate       DateTime? @map("due_date") @db.Date

  eventTypeId String? @map("event_type_id") @db.Uuid
  assetTypeId String? @map("asset_type_id") @db.Uuid
  assigneeId  String? @map("assignee_id") @db.Uuid // ← Airtable "Assigned Creative"

  // Two status axes (live values from reconciliation 2026-06-25):
  prioStatus   String? @map("prio_status") // New Request | To be reviewed by Vishen | In Queue | Pending Information/Brief Not Clear | Rejected - No need to work | Assigned
  ticketStatus String? @map("ticket_status") // Backlog | To Do | In Progress | Review | In Revision | Approved | Done | Won't Do | Shipping | Request on Hold

  urgency       Int?
  complexity    Int?
  priorityScore Decimal? @map("priority_score") @db.Decimal // derived; ranks the queue
  queueRank     Int?     @map("queue_rank") // ← Airtable "Priority ranking (Manual)"

  source    String    @default("app") // app | jira_migration | airtable
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  syncedAt  DateTime? @map("synced_at") @db.Timestamptz

  eventType EventType? @relation(fields: [eventTypeId], references: [id])
  assetType AssetType? @relation(fields: [assetTypeId], references: [id])
  assignee  Employee?  @relation(fields: [assigneeId], references: [id])

  events    TicketEvent[]
  approvals Approval[]
  shoots    ShootTicket[]
  assets    Asset[]

  @@index([priorityScore(sort: Desc), queueRank], map: "idx_tickets_queue")
  @@index([assigneeId], map: "idx_tickets_assignee")
  @@index([ticketStatus], map: "idx_tickets_status")
  @@map("tickets")
}

model TicketEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId  String?  @map("ticket_id") @db.Uuid
  fromState String?  @map("from_state")
  toState   String   @map("to_state")
  actorId   String?  @map("actor_id") @db.Uuid
  note      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  ticket Ticket?   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor  Employee? @relation(fields: [actorId], references: [id])

  @@map("ticket_events")
}

model Approval {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId   String?   @map("ticket_id") @db.Uuid
  approverId String?   @map("approver_id") @db.Uuid
  state      String    @default("pending") // pending | approved | changes_requested
  feedback   String?
  decidedAt  DateTime? @map("decided_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  ticket   Ticket?   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  approver Employee? @relation(fields: [approverId], references: [id])

  @@map("approvals")
}

model Shoot {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId String?   @unique @map("airtable_id")
  title      String
  status     String? // New Requests - Approved by Vishen | New Requests - Needs Vishen's Review | To Film | Done - Filmed | Cancelled
  shootDate  DateTime? @map("shoot_date") @db.Date
  location   String?
  notes      String?
  syncedAt   DateTime  @default(now()) @map("synced_at") @db.Timestamptz

  tickets ShootTicket[]

  @@map("shoots")
}

model ShootTicket {
  shootId  String @map("shoot_id") @db.Uuid
  ticketId String @map("ticket_id") @db.Uuid

  shoot  Shoot  @relation(fields: [shootId], references: [id], onDelete: Cascade)
  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@id([shootId, ticketId])
  @@map("shoot_tickets")
}

model Asset {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId      String?   @unique @map("airtable_id")
  ticketId        String?   @map("ticket_id") @db.Uuid
  kind            String // 'raw' | 'final'
  fileUrl         String?   @map("file_url") // Dropbox / storage link
  distributionUrl String?   @map("distribution_url") // link to social media calendar entry
  publishedAt     DateTime? @map("published_at") @db.Timestamptz
  syncedAt        DateTime  @default(now()) @map("synced_at") @db.Timestamptz

  ticket      Ticket?       @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  performance Performance[]

  @@map("assets")
}

model Performance {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetId    String?  @map("asset_id") @db.Uuid
  metric     String // e.g. CTR, views, spend, ROAS
  value      Decimal? @db.Decimal
  capturedAt DateTime @default(now()) @map("captured_at") @db.Timestamptz
  source     String? // e.g. Clarisights, Amplitude, manual

  asset Asset? @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("performance")
}
