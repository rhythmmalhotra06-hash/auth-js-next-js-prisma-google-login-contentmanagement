generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

// ===========================================================================
// AUTH.JS  (identity/session only; domain attribution lives on Employee)
// ===========================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ===========================================================================
// REFERENCE DATA  (one-way: Airtable -> Postgres; read-only in the app)
// ===========================================================================

model Employee {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId     String?  @unique @map("airtable_id")
  name           String
  email          String?  @unique
  team           String? // ← Airtable "Creative Team (Editors)": Content Production Video | Marketing Video | Organic Social Video | Design
  division       String? // ← Airtable "MV Entity"
  isTeamLead     Boolean  @default(false) @map("is_team_lead")
  employmentType String   @default("employee") @map("employment_type") // ← Airtable "Employment Status"
  active         Boolean  @default(true) // ← Airtable "Active Status": Active | Not Active
  roles          String[] @default([]) // ← Airtable "Roles" (multiselect): app access roles (Editor, Manager, Admin, …)
  capacity       Int? // ← Airtable "Capacity" (number): weighted load = 100%; blank → global default
  syncedAt       DateTime @default(now()) @map("synced_at") @db.Timestamptz

  assetTypeTeamLeads        AssetTypeTeamLead[]        @relation("AssetTypeTeamLead")
  assetTypePreferredEditors AssetTypePreferredEditor[] @relation("AssetTypePreferredEditor")
  assignedTickets           Ticket[]                   @relation("TicketAssignee")
  requestedTickets          Ticket[]                   @relation("TicketRequester")
  ticketEvents              TicketEvent[]
  approvals                 Approval[]
  contentSources            ContentSource[]            @relation("ContentSourceCreatedBy")

  @@map("employees")
}

model Dimension {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId String?  @unique @map("airtable_id")
  label      String // e.g. "9x16" — ← Airtable "Name" field
  syncedAt   DateTime @default(now()) @map("synced_at") @db.Timestamptz

  assetTypes AssetTypeDimension[]

  @@map("dimensions")
}

model EventType {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId     String?  @unique @map("airtable_id")
  name           String // e.g. Masterclass, Mastery, States, MBU, Social Media Promotion, Pathway
  brainProgramId String?  @map("brain_program_id") // [VERIFY] link to Mindvalley Brain
  active         Boolean  @default(true)
  loadWeight     Float?   @map("load_weight") // ← Airtable "Load Weight": capacity cost/ticket; blank → 1
  tierNorm       Float?   @map("tier_norm") // ← Airtable "Tier Norm" (0–1): priority event tier
  syncedAt       DateTime @default(now()) @map("synced_at") @db.Timestamptz

  assetTypes AssetTypeEventType[]
  tickets    Ticket[]

  @@map("event_types")
}

model Dna {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId        String?  @unique @map("airtable_id")
  name              String
  requirements      String?
  feedbackStandards String?  @map("feedback_standards")
  syncedAt          DateTime @default(now()) @map("synced_at") @db.Timestamptz

  assetTypes AssetType[]

  @@map("dna")
}

model AssetType {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId        String?  @unique @map("airtable_id")
  name              String // e.g. "Masterclass Trailer"
  fullName          String?  @map("full_name") // ← Airtable "Asset Type (Full title)": fallback when short name is blank
  category          String? // ← Airtable "Type of Asset": Print | Digital
  creativeCategory  String?  @map("creative_category") // ← Airtable "Category": Creative Video/Brand Design/Event Design Type
  dnaId             String?  @map("dna_id") @db.Uuid // legacy; DNA is dormant (text fields below are the live source, E9.7)
  active            Boolean  @default(true) // ← Airtable "Status": Active | Inactive
  loadWeight        Float?   @map("load_weight") // ← Airtable "Load Weight": capacity cost/ticket; blank → 1
  effortNorm        Float?   @map("effort_norm") // ← Airtable "Effort Norm" (0–1): priority complexity effort
  dnaRequirements   String?  @map("dna_requirements") // ← Airtable "DNA / Requirements" (E9.7)
  feedbackStandards String?  @map("feedback_standards") // ← Airtable "Feedback Standards" (E9.7)
  dnaUpdatedBy      String?  @map("dna_updated_by") // ← Airtable "DNA Updated By": last portal editor email
  syncedAt          DateTime @default(now()) @map("synced_at") @db.Timestamptz

  dna Dna? @relation(fields: [dnaId], references: [id])

  // Airtable models these as MULTIPLE record links → many-to-many (reconciliation 2026-06-25)
  eventTypes       AssetTypeEventType[]
  teamLeads        AssetTypeTeamLead[]
  preferredEditors AssetTypePreferredEditor[]

  dimensions AssetTypeDimension[]
  tickets    Ticket[]

  @@map("asset_types")
}

model AssetTypeDimension {
  assetTypeId String @map("asset_type_id") @db.Uuid
  dimensionId String @map("dimension_id") @db.Uuid

  assetType AssetType @relation(fields: [assetTypeId], references: [id], onDelete: Cascade)
  dimension Dimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  @@id([assetTypeId, dimensionId])
  @@map("asset_type_dimensions")
}

// Asset type ↔ event type (Airtable "Event Type" multi-link)
model AssetTypeEventType {
  assetTypeId String @map("asset_type_id") @db.Uuid
  eventTypeId String @map("event_type_id") @db.Uuid

  assetType AssetType @relation(fields: [assetTypeId], references: [id], onDelete: Cascade)
  eventType EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)

  @@id([assetTypeId, eventTypeId])
  @@map("asset_type_event_types")
}

// Asset type ↔ team lead employees (Airtable "Team Lead" multi-link)
model AssetTypeTeamLead {
  assetTypeId String @map("asset_type_id") @db.Uuid
  employeeId  String @map("employee_id") @db.Uuid

  assetType AssetType @relation(fields: [assetTypeId], references: [id], onDelete: Cascade)
  employee  Employee  @relation("AssetTypeTeamLead", fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([assetTypeId, employeeId])
  @@map("asset_type_team_leads")
}

// Asset type ↔ preferred editor employees (Airtable "Preferred Editors" multi-link)
model AssetTypePreferredEditor {
  assetTypeId String @map("asset_type_id") @db.Uuid
  employeeId  String @map("employee_id") @db.Uuid

  assetType AssetType @relation(fields: [assetTypeId], references: [id], onDelete: Cascade)
  employee  Employee  @relation("AssetTypePreferredEditor", fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([assetTypeId, employeeId])
  @@map("asset_type_preferred_editors")
}

// Contractors / freelancers — the second assignable pool (alongside Employee
// creatives). Reference: one-way Airtable → PG; edited in Airtable.
model Contractor {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId   String?  @unique @map("airtable_id")
  name         String
  active       Boolean  @default(true) // ← Airtable "Status": Active | …
  serviceLevel String?  @map("service_level") // ← Airtable "Team/Service Level"
  capacity     Int? // ← Airtable "Capacity" (number)
  syncedAt     DateTime @default(now()) @map("synced_at") @db.Timestamptz

  @@map("contractors")
}

// ⚙️ Scoring Config — app-owned global knobs (key→number). Mirrored one-way from
// Airtable for fast reads; edited at /settings/scoring (writes still go to Airtable,
// mirror refreshes). Per-type weights live on EventType/AssetType; per-person
// capacity on Employee/Contractor.
model ScoringConfigKnob {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId String?  @unique @map("airtable_id")
  key        String // stable config key (e.g. w_due, default_capacity)
  value      Float? // the numeric knob value
  label      String? // admin-panel label
  group      String? // Capacity | Priority weights | Thresholds
  note       String?
  updatedBy  String?  @map("updated_by")
  syncedAt   DateTime @default(now()) @map("synced_at") @db.Timestamptz

  @@map("scoring_config")
}

// 🧠 Clip Rules — editable clip-generation prompt/pillars/rules. Mirrored one-way
// from Airtable for fast reads; edited at /settings/clip-rules (writes go to Airtable).
model ClipRule {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId    String?  @unique @map("airtable_id")
  name          String?
  kind          String? // Base Prompt | Brand Pillars | Rule
  clipType      String?  @map("clip_type") // All | Reel | Stage Talk | Short
  content       String?
  active        Boolean  @default(true)
  order         Int? // sort for appended rules
  section       String? // General | Clips | Thumbnail | Titles | Distribution
  note          String?
  updatedBy     String?  @map("updated_by")
  airtableUpdatedAt String? @map("airtable_updated_at") // ← Airtable "Last Modified" string (display/sort)
  createdTime   String?  @map("created_time") // ← Airtable createdTime (display/sort)
  syncedAt      DateTime @default(now()) @map("synced_at") @db.Timestamptz

  @@map("clip_rules")
}

// ===========================================================================
// TRANSACTIONAL DATA  (two-way: app is primary, pushed back to Airtable)
// ===========================================================================

model Ticket {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId    String?   @unique @map("airtable_id")
  title         String // renamed from "Summary" for Dropbox searchability
  creativeBrief String?   @map("creative_brief")
  cta           String? // ← Airtable "Call to action"
  positioning   String? // messaging angle
  audience      String? // 'cold' | 'warm'
  dueDate       DateTime? @map("due_date") @db.Date

  eventTypeId        String? @map("event_type_id") @db.Uuid
  assetTypeId        String? @map("asset_type_id") @db.Uuid
  assigneeId         String? @map("assignee_id") @db.Uuid // ← Airtable "Assigned Creative"
  requesterId        String? @map("requester_id") @db.Uuid // ← Airtable "Requested By" (drives downstream lookups)
  officialCalendarId String? @map("official_calendar_id") @db.Uuid // ← Airtable "Official Calendar"

  teamServiceLevel String? @map("team_service_level") // ← "Team/Service Level"
  typeOfRequest    String? @map("type_of_request") // ← "Type of Request": Video | Design
  sourceLinks      String? @map("source_links") // ← "Raw File/Source URL/Stage Talk Links"
  downloadLink     String? @map("download_link") // ← editor download link (e.g. Dropbox) — E9.1
  notes            String? // ← "V's Notes"
  projectProgram   String? @map("project_program") // ← "Project/Program" (detail form)

  // Delivery links — discrete Prio fields the detail form edits directly (1:1 with Airtable,
  // so the two-way sync maps them field↔field). Distinct from the derived `assets` rows.
  assetFolderLink String? @map("asset_folder_link")
  workingFiles    String? @map("working_files")
  final16x9       String? @map("final_16x9")
  folder16x9      String? @map("folder_16x9")
  final9x16       String? @map("final_9x16")
  folder9x16      String? @map("folder_9x16")
  final4x5        String? @map("final_4x5")
  folder4x5       String? @map("folder_4x5")

  // Dedupe flag for the "asset ready" Slack notification (moved off the Airtable
  // "Asset Ready Notified" checkbox now that PG is the write source of truth).
  assetReadyNotified Boolean @default(false) @map("asset_ready_notified")

  // Two status axes (live values from reconciliation 2026-06-25):
  prioStatus   String? @map("prio_status") // New Request | To be reviewed by Vishen | In Queue | Pending Information/Brief Not Clear | Rejected - No need to work | Assigned
  ticketStatus String? @map("ticket_status") // Backlog | To Do | In Progress | Review | In Revision | Approved | Done | Won't Do | Shipping | Request on Hold

  urgency       Int?
  complexity    Int?
  priorityScore Decimal? @map("priority_score") @db.Decimal // derived; ranks the queue
  queueRank     Int?     @map("queue_rank") // ← Airtable "Priority ranking (Manual)"

  source    String    @default("app") // app | jira_migration | airtable
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  syncedAt  DateTime? @map("synced_at") @db.Timestamptz
  // Last time the app pushed this ticket to Airtable — echo-suppression window for
  // the (future) Phase 3 pull, so our own write doesn't ping-pong back.
  airtablePushedAt DateTime? @map("airtable_pushed_at") @db.Timestamptz

  eventType        EventType?        @relation(fields: [eventTypeId], references: [id])
  assetType        AssetType?        @relation(fields: [assetTypeId], references: [id])
  assignee         Employee?         @relation("TicketAssignee", fields: [assigneeId], references: [id])
  requester        Employee?         @relation("TicketRequester", fields: [requesterId], references: [id])
  officialCalendar OfficialCalendar? @relation(fields: [officialCalendarId], references: [id])

  events    TicketEvent[]
  approvals Approval[]
  shoots    ShootTicket[]
  assets    Asset[]
  authors   TicketAuthor[]

  clipSuggestions ClipSuggestion[] @relation("TicketClipSuggestions")

  @@index([priorityScore(sort: Desc), queueRank], map: "idx_tickets_queue")
  @@index([assigneeId], map: "idx_tickets_assignee")
  @@index([ticketStatus], map: "idx_tickets_status")
  @@map("tickets")
}

// Phase 2 — outbox for two-way PUSH (portal → Airtable). Writes enqueue a row in the
// same transaction; a background drainer (drainOutbox) pushes current state to the
// target Airtable table, batched + rate-limited. We enqueue by (entity, entityId) —
// not a field snapshot — so the drainer always sends the latest state and collapses
// rapid successive edits.
//
// POLYMORPHIC (0012): `entity` names the domain ('ticket' | 'shoot' | 'social' | …)
// and `entityId` is that domain's internal PG id (uuid-as-text) or a domain key.
// The drainer dispatches on `entity` via lib/airtable/push-registry.ts. `ticketId`
// is retained (nullable) for in-flight rows enqueued before the migration; the
// drainer falls back to it when `entityId` is null (legacy 'ticket' rows).
model AirtableOutbox {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entity      String    @default("ticket") // domain discriminator → push-registry key
  entityId    String?   @map("entity_id") // internal PG id (text) of the domain row; null only on legacy rows
  ticketId    String?   @map("ticket_id") @db.Uuid // DEPRECATED: legacy fallback for pre-0012 rows
  op          String    @default("upsert") // upsert (create-or-update) | delete
  status      String    @default("pending") // pending | done | error
  attempts    Int       @default(0)
  lastError   String?   @map("last_error")
  enqueuedAt  DateTime  @default(now()) @map("enqueued_at") @db.Timestamptz
  processedAt DateTime? @map("processed_at") @db.Timestamptz

  @@index([status, enqueuedAt], map: "idx_outbox_pending")
  @@index([entity, entityId], map: "idx_outbox_entity")
  @@map("airtable_outbox")
}

model TicketEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId  String?  @map("ticket_id") @db.Uuid
  fromState String?  @map("from_state")
  toState   String   @map("to_state")
  actorId   String?  @map("actor_id") @db.Uuid
  note      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  ticket Ticket?   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor  Employee? @relation(fields: [actorId], references: [id])

  @@map("ticket_events")
}

model Approval {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId   String?   @map("ticket_id") @db.Uuid
  approverId String?   @map("approver_id") @db.Uuid
  state      String    @default("pending") // pending | approved | changes_requested
  feedback   String?
  decidedAt  DateTime? @map("decided_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  ticket   Ticket?   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  approver Employee? @relation(fields: [approverId], references: [id])

  @@map("approvals")
}

// Shoots — pre-production filming requests. PG system-of-record with two-way Airtable
// sync (SHOOTS_BACKEND). Link fields (requester/authors/event types/asset-library/tickets)
// are stored as Airtable recId arrays — the shoot's OWN state is authoritative here; the
// drainer pushes these back to Airtable as link arrays. `notes`/`location` columns are
// reused (from the original reference model) as brief/filmingLocation. `shoot_date` column
// is legacy/dead (superseded by filming_date text).
model Shoot {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId        String?   @unique @map("airtable_id")
  title             String?
  status            String? // New Requests - Approved/Needs Review | To Film | Done - Filmed | Cancelled
  format            String?
  filmingDate       String?   @map("filming_date") // raw Airtable "Filming Date" string
  filmingLocation   String?   @map("location") // reuse legacy `location` column
  brief             String?   @map("notes") // reuse legacy `notes` column (Airtable notes)
  productionSupport String?   @map("production_support")
  vishenApproved    Boolean   @default(false) @map("vishen_approved")
  priorityRanking   Int?      @map("priority_ranking")
  rawFiles          String?   @map("raw_files")
  platforms         String[]  @default([])
  newPrioTicket     Boolean   @default(false) @map("new_prio_ticket")
  requestedById     String?   @map("requested_by_id") // Airtable Employee recId
  authorIds         String[]  @default([]) @map("author_ids")
  eventTypeIds      String[]  @default([]) @map("event_type_ids")
  assetTypeIds      String[]  @default([]) @map("asset_type_ids") // "Creative Asset Type" link (set at create; round-tripped, not read into ShootRow)
  assetLibraryIds   String[]  @default([]) @map("asset_library_ids")
  ticketIds         String[]  @default([]) @map("ticket_ids")
  createdTime       String?   @map("created_time") // Airtable createdTime (list ordering)
  airtablePushedAt  DateTime? @map("airtable_pushed_at") @db.Timestamptz // echo-suppression window
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  syncedAt          DateTime  @default(now()) @map("synced_at") @db.Timestamptz

  tickets ShootTicket[]

  @@index([airtablePushedAt], map: "idx_shoots_pushed")
  @@map("shoots")
}

model ShootTicket {
  shootId  String @map("shoot_id") @db.Uuid
  ticketId String @map("ticket_id") @db.Uuid

  shoot  Shoot  @relation(fields: [shootId], references: [id], onDelete: Cascade)
  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@id([shootId, ticketId])
  @@map("shoot_tickets")
}

model Asset {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId      String?   @unique @map("airtable_id")
  ticketId        String?   @map("ticket_id") @db.Uuid
  kind            String // 'raw' | 'final'
  name            String? // asset title (library imports have no ticket to name them)
  sourceTable     String?   @map("source_table") // provenance: which Airtable table/origin this asset came from
  fileUrl         String?   @map("file_url") // Dropbox / storage link
  distributionUrl String?   @map("distribution_url") // link to social media calendar entry
  publishedAt     DateTime? @map("published_at") @db.Timestamptz
  syncedAt        DateTime  @default(now()) @map("synced_at") @db.Timestamptz

  ticket      Ticket?       @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  performance Performance[]

  @@map("assets")
}

model Performance {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetId    String?  @map("asset_id") @db.Uuid
  metric     String // e.g. CTR, views, spend, ROAS
  value      Decimal? @db.Decimal
  capturedAt DateTime @default(now()) @map("captured_at") @db.Timestamptz
  source     String? // e.g. Clarisights, Amplitude, manual

  asset Asset? @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("performance")
}

// Official Calendar (reference, synced from Airtable) — campaign start/end dates.
model OfficialCalendar {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId  String?   @unique @map("airtable_id")
  name        String // ← "Name of project"
  status      String? // Proposal | Confirmed | Completed | …
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  syncedAt    DateTime  @default(now()) @map("synced_at") @db.Timestamptz

  tickets Ticket[]

  @@map("official_calendar")
}

// Authors / speakers (reference, synced from Airtable).
model Author {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId String?  @unique @map("airtable_id")
  name       String
  title      String? // ← "Author's Title"
  syncedAt   DateTime @default(now()) @map("synced_at") @db.Timestamptz

  tickets TicketAuthor[]

  @@map("authors")
}

// Ticket ↔ authors/speakers (Airtable "Speakers/Authors" multi-link).
model TicketAuthor {
  ticketId String @map("ticket_id") @db.Uuid
  authorId String @map("author_id") @db.Uuid

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@id([ticketId, authorId])
  @@map("ticket_authors")
}

// 📣 Social — Marketing content board (Content & Comms base). PG system-of-record with
// two-way Airtable sync (SOCIAL_BACKEND). Only the app-managed fields live here; other
// columns on the Airtable row (social format, content type, transcript, shoots link) are
// left untouched by the drainer. `creativeTicketId` is a Creative Services ticket recId
// stored as text (cross-base — can't be an Airtable link); `officialCalId` is a same-base
// link to CommsCalendar (recId).
model SocialPost {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId       String?   @unique @map("airtable_id")
  title            String?
  notes            String?
  captions         String?
  status           String? // 1: Proposal | 2: Approved | 2A. Ticket Raised | 13: Reject
  clipSourceUrl    String?   @map("clip_source_url") // engine-origin marker + grouping key
  sourceTitle      String?   @map("source_title")
  viralityScore    Int?      @map("virality_score")
  timecode         String?
  creativeTicketId String?   @map("creative_ticket_id") // Creative Services ticket recId (text; presence ⇒ raised)
  officialCalId    String?   @map("official_cal_id") // Content & Comms calendar recId (same-base link)
  createdTime      String?   @map("created_time")
  airtablePushedAt DateTime? @map("airtable_pushed_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  syncedAt         DateTime  @default(now()) @map("synced_at") @db.Timestamptz

  @@index([airtablePushedAt], map: "idx_social_pushed")
  @@map("social_posts")
}

// 📺 Media Sources — the media inbox (app-owned, Creative Services base). READ-MIRROR:
// PG is a fast read replica (MEDIA_BACKEND); writes still go to Airtable (createMediaSource/
// updateMediaSource, incl. the vishen-sync cross-base fan-out) and are write-through-upserted
// here, plus a pull catches external edits. No outbox — Airtable stays the source of truth.
// Link fields are kept as Airtable recId arrays/scalars. Clip Suggestions are NOT mirrored.
model MediaSource {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId               String?  @unique @map("airtable_id")
  title                    String?
  sourceUrl                String?  @map("source_url")
  downloadUrl              String?  @map("download_url")
  platform                 String?
  status                   String?
  guestShow                String?  @map("guest_show")
  audience                 String?
  submittedVia             String?  @map("submitted_via")
  usedWebSearch            Boolean  @default(false) @map("used_web_search")
  strategyJson             String?  @map("strategy_json")
  transcript               String?
  error                    String?
  submittedDate            String?  @map("submitted_date")
  clipsAddedDate           String?  @map("clips_added_date")
  clipSuggestionIds        String[] @default([]) @map("clip_suggestion_ids")
  submittedById            String?  @map("submitted_by_id")
  ticketEventTypeId        String?  @map("ticket_event_type_id")
  ticketAssetTypeId        String?  @map("ticket_asset_type_id")
  ticketOfficialCalendarId String?  @map("ticket_official_calendar_id")
  ticketDueDate            String?  @map("ticket_due_date")
  sourceRecordId           String?  @map("source_record_id")
  createdTime              String?  @map("created_time")
  syncedAt                 DateTime @default(now()) @map("synced_at") @db.Timestamptz

  @@map("media_sources")
}

// 🎬 Vishen's Videos — his complete cross-channel content log (team-maintained by hand).
// PG system-of-record with two-way Airtable sync (VISHEN_VIDEOS_BACKEND). The team edits most
// fields in Airtable (pulled in); the portal writes back ONLY approval/rating/views24h on an
// explicit tap (loop-safe — no inbound automation reads them, Status is never written), so the
// push-map touches only those three fields. `stage`/`channel` are derived in code, not stored.
model VishenVideo {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId       String?   @unique @map("airtable_id")
  name             String?
  source           String? // producer/agency
  medium           String?
  format           String?
  product          String?
  status           String? // 6-stage pipeline (read-only from the app)
  approval         String? // Vishen's sign-off (app writes)
  publishedLink    String?   @map("published_link")
  liveDate         String?   @map("live_date")
  rating           Int? // 1–5 (app writes)
  views24h         String?   @map("views_24h") // team-logged 24h perf (app writes)
  createdTime      String?   @map("created_time")
  airtablePushedAt DateTime? @map("airtable_pushed_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  syncedAt         DateTime  @default(now()) @map("synced_at") @db.Timestamptz

  @@index([airtablePushedAt], map: "idx_vishen_videos_pushed")
  @@map("vishen_videos")
}

// 📅 Content & Comms campaign calendar (distinct from OfficialCalendar). Reference:
// one-way Airtable → PG; edited in Airtable. Powers the /social/new calendar picker.
model CommsCalendar {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  airtableId String?  @unique @map("airtable_id")
  name       String
  status     String?
  startDate  String?  @map("start_date") // raw Airtable date string (display/sort)
  endDate    String?  @map("end_date")
  syncedAt   DateTime @default(now()) @map("synced_at") @db.Timestamptz

  @@map("comms_calendars")
}

// ===========================================================================
// AI CONTENT CLIPPING ENGINE (E8)
// Transcript → 10-section viral strategy → selectable clips → proposed tickets.
// ===========================================================================

// One long-form transcript + the context it was generated with.
model ContentSource {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String
  sourceType    String   @map("source_type") // paste | file | youtube
  sourceUrl     String?  @map("source_url")
  guestName     String?  @map("guest_name")
  guestAudience String?  @map("guest_audience")
  brandPillars  String?  @map("brand_pillars")
  transcript    String   @db.Text
  createdById   String?  @map("created_by_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  createdBy  Employee?      @relation("ContentSourceCreatedBy", fields: [createdById], references: [id])
  strategies ClipStrategy[]

  @@map("content_sources")
}

// One generation run: the full 10-section strategy lives in `output` (JSON).
model ClipStrategy {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contentSourceId String   @map("content_source_id") @db.Uuid
  model           String
  status          String   @default("generating") // generating | complete | error
  error           String?
  output          Json?
  usedWebSearch   Boolean  @default(false) @map("used_web_search")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  contentSource ContentSource    @relation(fields: [contentSourceId], references: [id], onDelete: Cascade)
  clips         ClipSuggestion[]

  @@index([contentSourceId], map: "idx_clip_strategies_source")
  @@map("clip_strategies")
}

// The Reels clips, broken out for propose → approve → ticket tracking.
model ClipSuggestion {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clipStrategyId String  @map("clip_strategy_id") @db.Uuid
  index          Int
  title          String
  timestampStart String? @map("timestamp_start")
  timestampEnd   String? @map("timestamp_end")
  rationale      String?
  caption        String?
  hookLine       String? @map("hook_line")
  format         String?
  platform       String?
  viralityScore  Int?    @map("virality_score")
  status         String  @default("proposed") // proposed | approved | dismissed
  ticketId       String? @map("ticket_id") @db.Uuid

  clipStrategy ClipStrategy @relation(fields: [clipStrategyId], references: [id], onDelete: Cascade)
  ticket       Ticket?      @relation("TicketClipSuggestions", fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([clipStrategyId], map: "idx_clip_suggestions_strategy")
  @@map("clip_suggestions")
}

// ===========================================================================
// METRIC SNAPSHOTS — precomputed aggregates
// ===========================================================================

// Precomputed aggregate snapshots so dashboards read one cheap row instead of
// scanning the ~10k-row Airtable ticket table on every page load. Refreshed by
// POST /api/metrics/refresh (nightly cron). `data` holds an arbitrary payload
// keyed by `key` (e.g. "ticket_status_counts" → { total, byStatus, shipped }).
model MetricSnapshot {
  key        String   @id
  data       Json
  computedAt DateTime @updatedAt @map("computed_at")

  @@map("metric_snapshots")
}

// Small key→value store for sync watermarks (e.g. the ticket inbound-pull cursor:
// the newest Airtable "Last Modified" time we've imported). Keeps the two-way pull
// incremental instead of rescanning the whole table each cycle.
model SyncState {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("sync_state")
}
